{
  "plugin_id": "continuum.tvdb",
  "version": "1.2.4",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "supported_platforms": [
    {
      "os": "darwin",
      "arch": "arm64"
    },
    {
      "os": "linux",
      "arch": "amd64"
    },
    {
      "os": "linux",
      "arch": "arm64"
    }
  ],
  "capabilities": [
    {
      "type": "metadata_provider.v1",
      "id": "tvdb",
      "display_name": "TVDB",
      "description": "TVDB metadata provider for Continuum."
    }
  ],
  "global_config_schema": [
    {
      "key": "connection",
      "title": "Connection",
      "description": "TVDB API key and subscriber PIN.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"api_key\":{\"type\":\"string\",\"minLength\":1},\"pin\":{\"type\":\"string\",\"minLength\":1}},\"required\":[\"api_key\",\"pin\"],\"additionalProperties\":false}",
      "admin_form": {
        "submit_label": "Save credentials",
        "fields": [
          {
            "key": "api_key",
            "label": "TVDB API Key",
            "description": "Paste the API key from your TVDB account settings.",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true,
            "placeholder": "Enter TVDB API key"
          },
          {
            "key": "pin",
            "label": "Subscriber PIN",
            "description": "Enter the subscriber PIN associated with your TVDB account.",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true,
            "placeholder": "Enter TVDB subscriber PIN"
          }
        ]
      }
    }
  ]
}
